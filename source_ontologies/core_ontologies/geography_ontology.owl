  <rdf:Description rdf:about="https://veerla-ramrao.ai/ontology/geography">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:title>Veerla Ram Rao Geography Ontology</dcterms:title>
    <dcterms:description>A class-based geography ontology for GraphRAG/document parsing. Specific continents, regions, and countries are modeled as OWL classes so document-derived mentions can be instantiated directly as members of those classes.</dcterms:description>
    <dcterms:creator>Generated for Venkat Ram Rao</dcterms:creator>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <owl:versionInfo>0.1.0</owl:versionInfo>
  </rdf:Description>
