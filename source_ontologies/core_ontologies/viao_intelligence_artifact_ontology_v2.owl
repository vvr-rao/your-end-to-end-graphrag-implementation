<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xmlns="https://veerla-ramrao.ai/ontology/intelligence-artifact#"
    xml:base="https://veerla-ramrao.ai/ontology/intelligence-artifact"
    xmlns:viao="https://veerla-ramrao.ai/ontology/intelligence-artifact#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:dcterms="http://purl.org/dc/terms/"
    xmlns:vann="http://purl.org/vocab/vann/"
    xmlns:skos="http://www.w3.org/2004/02/skos/core#">

    <owl:Ontology rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact">
        <rdfs:label xml:lang="en">Veerla Intelligence Artifact Ontology (VIAO)</rdfs:label>
        <dcterms:title xml:lang="en">Veerla Intelligence Artifact Ontology</dcterms:title>
        <dcterms:alternative xml:lang="en">VIAO</dcterms:alternative>
        <dcterms:creator xml:lang="en">Venkat Ram Rao / Veerla Ram Rao</dcterms:creator>
        <dcterms:publisher xml:lang="en">Veerla Ram Rao</dcterms:publisher>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-06</dcterms:created>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-06</dcterms:modified>
        <owl:versionInfo>0.1.0</owl:versionInfo>
        <dcterms:description xml:lang="en">
            VIAO is a lightweight ontology for representing source documents, text chunks, and generated intelligence artifacts in GraphRAG, document intelligence, and knowledge management systems. It distinguishes raw information sources from derived intelligence artifacts such as summaries, assertions, facts, claims, observations, insights, findings, conclusions, risks, and recommendations.
        </dcterms:description>
        <rdfs:comment xml:lang="en">
            Namespace convention: use https://veerla-ramrao.ai/ontology/intelligence-artifact# for ontology terms such as classes and properties. Runtime instances should generally use https://veerla-ramrao.ai/resource/ or a project-specific resource namespace. Example ontology term: https://veerla-ramrao.ai/ontology/intelligence-artifact#Document. Example resource instance: https://veerla-ramrao.ai/resource/document/apple-10k-2025.
        </rdfs:comment>
        <vann:preferredNamespacePrefix>viao</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://veerla-ramrao.ai/ontology/intelligence-artifact#</vann:preferredNamespaceUri>
        <dcterms:identifier>https://veerla-ramrao.ai/ontology/intelligence-artifact</dcterms:identifier>
        <dcterms:subject xml:lang="en">GraphRAG</dcterms:subject>
        <dcterms:subject xml:lang="en">Document Intelligence</dcterms:subject>
        <dcterms:subject xml:lang="en">Knowledge Management</dcterms:subject>
        <dcterms:subject xml:lang="en">Ontology</dcterms:subject>
    </owl:Ontology>

    <!-- Classes -->

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource">
        <rdfs:label xml:lang="en">Information Source</rdfs:label>
        <rdfs:comment xml:lang="en">A raw or semi-raw source of information from which intelligence artifacts may be derived.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Document">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource"/>
        <rdfs:label xml:lang="en">Document</rdfs:label>
        <rdfs:comment xml:lang="en">A source document, such as a PDF, Word file, slide deck, web page, annual report, transcript, policy document, article, or other ingested source.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Chunk">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource"/>
        <rdfs:label xml:lang="en">Chunk</rdfs:label>
        <rdfs:comment xml:lang="en">A segment of a document created for retrieval, embedding, indexing, citation, summarization, or evidence tracking.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact">
        <rdfs:label xml:lang="en">Intelligence Artifact</rdfs:label>
        <rdfs:comment xml:lang="en">A generated or curated knowledge object derived from one or more information sources, such as a summary, assertion, insight, or recommendation.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Summary">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">Summary</rdfs:label>
        <rdfs:comment xml:lang="en">Condensed representation of source content.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Assertion">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">Assertion</rdfs:label>
        <rdfs:comment xml:lang="en">A statement made about a source, entity, concept, event, metric, or situation. Assertions may include facts, claims, or observations.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Fact">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Assertion"/>
        <rdfs:label xml:lang="en">Fact</rdfs:label>
        <rdfs:comment xml:lang="en">Statement supported by evidence and presented as true.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Claim">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Assertion"/>
        <rdfs:label xml:lang="en">Claim</rdfs:label>
        <rdfs:comment xml:lang="en">Statement asserted by a source whose truth may not be verified.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Observation">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Assertion"/>
        <rdfs:label xml:lang="en">Observation</rdfs:label>
        <rdfs:comment xml:lang="en">Directly observed pattern or condition.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Insight">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">Insight</rdfs:label>
        <rdfs:comment xml:lang="en">A higher-level interpretation derived from assertions, observations, evidence, or analysis.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Finding">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Insight"/>
        <rdfs:label xml:lang="en">Finding</rdfs:label>
        <rdfs:comment xml:lang="en">Analytical result derived from observations/assertions.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Conclusion">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Insight"/>
        <rdfs:label xml:lang="en">Conclusion</rdfs:label>
        <rdfs:comment xml:lang="en">Judgment derived from findings.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Risk">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Insight"/>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
        <rdfs:comment xml:lang="en">Potential future adverse outcome.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Recommendation">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">Recommendation</rdfs:label>
        <rdfs:comment xml:lang="en">Suggested action based on findings or risks.</rdfs:comment>
    </owl:Class>

    <!-- Event artifact (Phase 2a follow-up, 2026-06-15) -->

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#Event">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">Event</rdfs:label>
        <rdfs:comment xml:lang="en">A happening anchored to a date or a date range. Captures studies / market research, publication of reports or study results, product releases, elections, company foundings, and similar time-anchored occurrences. Use `eventDate` for instantaneous events and `eventStartDate` / `eventEndDate` for ranges.</rdfs:comment>
    </owl:Class>

    <!-- Structured table artifact (Phase 2a) -->

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable">
        <rdfs:subClassOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">Structured Table</rdfs:label>
        <rdfs:comment xml:lang="en">A table of values extracted from a source document and preserved as a JSON-LD structure. Supports nested tables, multi-row headers, and merged cells. Common origin: financial-statement tables in 10-K / 20-F / annual report PDFs.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableColumn">
        <rdfs:label xml:lang="en">Table Column</rdfs:label>
        <rdfs:comment xml:lang="en">A column within a StructuredTable. Carries a column label (typically the heading) and identifies the values in each row.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableRow">
        <rdfs:label xml:lang="en">Table Row</rdfs:label>
        <rdfs:comment xml:lang="en">A row within a StructuredTable. Carries an optional row label (the leftmost label cell) and one TableCell per column.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableCell">
        <rdfs:label xml:lang="en">Table Cell</rdfs:label>
        <rdfs:comment xml:lang="en">A single cell at the intersection of a TableRow and a TableColumn. Holds the cell value (string, number, or nested table reference) and may carry colspan/rowspan attributes.</rdfs:comment>
    </owl:Class>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#hasChunk">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Document"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Chunk"/>
        <owl:inverseOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#chunkOf"/>
        <rdfs:label xml:lang="en">has chunk</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a document to a chunk derived from that document.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#chunkOf">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Chunk"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Document"/>
        <rdfs:label xml:lang="en">chunk of</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a chunk back to its source document.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#hasIntelligenceArtifact">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">has intelligence artifact</rdfs:label>
        <rdfs:comment xml:lang="en">Connects an information source to an intelligence artifact generated from or associated with it.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#derivedFrom">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource"/>
        <rdfs:label xml:lang="en">derived from</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that an intelligence artifact was derived from an information source such as a document or chunk.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#derivedFromDocument">
        <rdfs:subPropertyOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#derivedFrom"/>
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Document"/>
        <rdfs:label xml:lang="en">derived from document</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that an intelligence artifact was derived from a source document.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#derivedFromChunk">
        <rdfs:subPropertyOf rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#derivedFrom"/>
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Chunk"/>
        <rdfs:label xml:lang="en">derived from chunk</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that an intelligence artifact was derived from a specific text chunk.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#referencesChunk">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Chunk"/>
        <rdfs:label xml:lang="en">references chunk</rdfs:label>
        <rdfs:comment xml:lang="en">Links an intelligence artifact to a chunk that supports, explains, or is cited by it.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#referencesArtifact">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:label xml:lang="en">references artifact</rdfs:label>
        <rdfs:comment xml:lang="en">Links one intelligence artifact to another intelligence artifact.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#summarizes">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Summary"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource"/>
        <rdfs:label xml:lang="en">summarizes</rdfs:label>
        <rdfs:comment xml:lang="en">Indicates that a summary summarizes a document, chunk, or other information source.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#assertsAbout">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Assertion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:label xml:lang="en">asserts about</rdfs:label>
        <rdfs:comment xml:lang="en">Connects an assertion to the entity, concept, event, metric, source, or subject it is about.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#insightBasedOn">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Insight"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Assertion"/>
        <rdfs:label xml:lang="en">insight based on</rdfs:label>
        <rdfs:comment xml:lang="en">Connects an insight to one or more assertions that support it.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#recommendationBasedOn">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Recommendation"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Insight"/>
        <rdfs:label xml:lang="en">recommendation based on</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a recommendation to the insight or risk that motivates it.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Structured-table object properties (Phase 2a) -->

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#hasColumn">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableColumn"/>
        <rdfs:label xml:lang="en">has column</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a StructuredTable to one of its TableColumns.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#hasRow">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableRow"/>
        <rdfs:label xml:lang="en">has row</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a StructuredTable to one of its TableRows.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#hasCell">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableRow"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableCell"/>
        <rdfs:label xml:lang="en">has cell</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a TableRow to one of its TableCells.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#inColumn">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableCell"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableColumn"/>
        <rdfs:label xml:lang="en">in column</rdfs:label>
        <rdfs:comment xml:lang="en">Identifies which TableColumn a TableCell belongs to.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#hasNestedTable">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableCell"/>
        <rdfs:range rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable"/>
        <rdfs:label xml:lang="en">has nested table</rdfs:label>
        <rdfs:comment xml:lang="en">When a TableCell contains a sub-table rather than a scalar value, this property links to the nested StructuredTable.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Data Properties -->

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#content">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#InformationSource"/>
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">content</rdfs:label>
        <rdfs:comment xml:lang="en">Textual content of a source, chunk, or intelligence artifact.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#confidenceScore">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#IntelligenceArtifact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">confidence score</rdfs:label>
        <rdfs:comment xml:lang="en">Numeric confidence value assigned to an intelligence artifact, typically between 0 and 1.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#sourceUri">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Document"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:label xml:lang="en">source URI</rdfs:label>
        <rdfs:comment xml:lang="en">URI, file path, or external locator for a source document.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#chunkIndex">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">chunk index</rdfs:label>
        <rdfs:comment xml:lang="en">Ordinal position of a chunk within its source document.</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- Structured-table data properties (Phase 2a) -->

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#tableCaption">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">table caption</rdfs:label>
        <rdfs:comment xml:lang="en">Human-readable caption / title describing what the table contains. Typically extracted from the document's heading immediately above the table.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#pageNumber">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">page number</rdfs:label>
        <rdfs:comment xml:lang="en">Page of the source document on which the table appears.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#columnLabel">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableColumn"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">column label</rdfs:label>
        <rdfs:comment xml:lang="en">Header text for a TableColumn. Phase 1's expand/prune-expand passes turn these into candidate ontology data-properties / classes.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#columnIndex">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableColumn"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">column index</rdfs:label>
        <rdfs:comment xml:lang="en">Zero-based ordinal position of the column within its StructuredTable.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#rowLabel">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableRow"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">row label</rdfs:label>
        <rdfs:comment xml:lang="en">Leftmost label cell of a TableRow, when present. Often the name of the row's subject (e.g. a segment, line item, or geography).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#rowIndex">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableRow"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">row index</rdfs:label>
        <rdfs:comment xml:lang="en">Zero-based ordinal position of the row within its StructuredTable.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#cellValue">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableCell"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">cell value</rdfs:label>
        <rdfs:comment xml:lang="en">String representation of a TableCell's value. Numeric / currency / date values are stored as-extracted (units preserved); downstream consumers parse on demand.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#isHeaderRow">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#TableRow"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:label xml:lang="en">is header row</rdfs:label>
        <rdfs:comment xml:lang="en">Flag set to true when the row carries column-header cells rather than data cells. Some tables have multiple header rows for multi-level headings.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#extractionMethod">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#StructuredTable"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">extraction method</rdfs:label>
        <rdfs:comment xml:lang="en">How this StructuredTable was extracted from its source. Expected values: 'pdfplumber' (deterministic library), 'vision-llm' (gpt-4o-mini vision route used for nested / complex tables), 'manual' (curated).</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- Event data properties (Phase 2a follow-up, 2026-06-15) -->

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#eventDate">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">event date</rdfs:label>
        <rdfs:comment xml:lang="en">Single date on which the event occurred. Use this for instantaneous events (e.g. report publication, product release, election day, company founding).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#eventStartDate">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">event start date</rdfs:label>
        <rdfs:comment xml:lang="en">Start date of an event with a duration (e.g. a market-research study, a campaign, a war).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#eventEndDate">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="en">event end date</rdfs:label>
        <rdfs:comment xml:lang="en">End date of an event with a duration. Omit (or leave null) for ongoing events.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="https://veerla-ramrao.ai/ontology/intelligence-artifact#eventCategory">
        <rdfs:domain rdf:resource="https://veerla-ramrao.ai/ontology/intelligence-artifact#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="en">event category</rdfs:label>
        <rdfs:comment xml:lang="en">Optional short label for the kind of event (e.g. "study", "publication", "release", "election", "founding", "campaign"). Free-text; not constrained by a fixed vocabulary.</rdfs:comment>
    </owl:DatatypeProperty>

</rdf:RDF>
