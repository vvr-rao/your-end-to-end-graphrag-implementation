# =============================================================================
# .env.example
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
#   cp .env.example .env
#
# Loaded at startup by python-dotenv + pydantic-settings (see backend/app/core/config.py).
# Missing required keys cause the app to fail fast with a useful error.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (required)
#
# Paste your Supabase connection string directly — the app auto-normalizes the
# scheme to `postgresql+asyncpg://` and, for any *.supabase.co / *.supabase.com
# host, force-appends `?sslmode=require` if it's missing (defense-in-depth).
#
# Three formats below — pick one and keep the `?sslmode=require` suffix:
#
# A) Supabase Session Pooler (recommended for cloud / prod — IPv4 reachable,
#    works from Render, supports prepared statements). Find this URL in
#    Supabase Dashboard → Project Settings → Database → "Session pooler".
#    Note: username is `postgres.<project-ref>` (project-ref in the username),
#    hostname is `aws-N-<region>.pooler.supabase.com`, port 5432.
#
#    postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#
# B) Supabase Direct connection. NOTE: only IPv6 — will time out from IPv4-only
#    networks (including most local dev and Render's starter tier). Prefer A
#    unless you have confirmed IPv6 routing.
#
#    postgresql://postgres:PASSWORD@db.<project>.supabase.co:5432/postgres?sslmode=require
#
# C) Local docker-compose (dev only — SSL not used; the validator won't add it):
#    postgresql://ontologist:ontologist@localhost:5432/ontologist
#
# IMPORTANT: `?sslmode=require` is REQUIRED for any cloud connection. asyncpg's
# default sslmode is `prefer` which silently falls back to plaintext if the
# server allows it — Supabase's pooler does allow plaintext, so without
# `sslmode=require` your password and every query travel unencrypted over the
# public internet. The validator adds it automatically for Supabase hostnames,
# but include it explicitly in case you change the DSN later.
#
# PGVECTOR: this app stores OpenAI embeddings in `vector(1536)` columns and
# does ANN search via pgvector's HNSW index. You must enable the extension
# once per database. In Supabase:
#   Dashboard → Database → Extensions → search "vector" → toggle ON
# Or as a privileged role:  CREATE EXTENSION IF NOT EXISTS vector;
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# Redis (required — used by arq for background jobs)
# Local docker-compose default.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LLM provider API keys
#   OPENAI_API_KEY — required (class_proposal, match_dedup, class_summarization,
#                              qa_synthesis, embeddings)
#   GROQ_API_KEY   — required (chunk_classification — document ingestion tagging)
# See config/models.example.yaml for the task→provider map.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# -----------------------------------------------------------------------------
# Render deployment (only required when deploying via Render API)
# -----------------------------------------------------------------------------
RENDER_API_KEY=

# -----------------------------------------------------------------------------
# Local file storage (where uploaded raw PDF/PPTX/DOCX/TXT files live)
# Defaults to ./uploads inside the repo for local dev.
# In Render, point at the persistent disk mount path (e.g. /var/data/uploads).
# -----------------------------------------------------------------------------
STORAGE_DIR=./uploads

# -----------------------------------------------------------------------------
# API auth (single shared bearer token for Phases 1–3; real auth deferred)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------------------------
BEARER_TOKEN=replace-me-with-a-strong-random-token

# -----------------------------------------------------------------------------
# Frontend origin (for CORS). In dev, Vite serves on :5173. In Render prod,
# set this to the static-site URL (e.g. https://your-frontend.onrender.com).
# -----------------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Logging / runtime
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENV=development
