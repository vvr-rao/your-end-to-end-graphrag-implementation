# =============================================================================
# .env.example
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
#   cp .env.example .env
#
# Loaded at startup by python-dotenv + pydantic-settings (see backend/app/core/config.py).
# Missing required keys cause the app to fail fast with a useful error.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (required)
# Local docker-compose default. Override for staging/prod.
# Format: postgresql+asyncpg://USER:PASS@HOST:PORT/DB
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ontologist:ontologist@localhost:5432/ontologist

# -----------------------------------------------------------------------------
# Redis (required — used by arq for background jobs)
# Local docker-compose default.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LLM provider API keys (at least one required; ideally all three for the
# multi-provider router. See config/models.example.yaml for the task→provider map.)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# -----------------------------------------------------------------------------
# Render deployment (only required when deploying via Render API)
# -----------------------------------------------------------------------------
RENDER_API_KEY=

# -----------------------------------------------------------------------------
# Local file storage (where uploaded raw PDF/PPTX/DOCX/TXT files live)
# Defaults to ./uploads inside the repo for local dev.
# In Render, point at the persistent disk mount path (e.g. /var/data/uploads).
# -----------------------------------------------------------------------------
STORAGE_DIR=./uploads

# -----------------------------------------------------------------------------
# API auth (single shared bearer token for Phases 1–3; real auth deferred)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# -----------------------------------------------------------------------------
BEARER_TOKEN=replace-me-with-a-strong-random-token

# -----------------------------------------------------------------------------
# Logging / runtime
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENV=development
